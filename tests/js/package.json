{
  "name": "deepgraph-dashboard-e2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Frontend tests for the DeepGraph dashboard: graph adapter unit + perf, renderer perf (jsdom), and the Playwright responsiveness gate (issue #19 / #34).",
  "scripts": {
    "test:adapter": "node graph_adapter.test.mjs",
    "test:renderer": "node graph_renderer_perf.mjs",
